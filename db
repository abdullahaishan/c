-- سياسات للمطورين (يمكن للجميع قراءة المطورين النشطين)
CREATE POLICY "المطورين النشطين مرئيون للجميع" ON developers
    FOR SELECT USING (is_active = true);

-- سياسات للمشاريع (يمكن للجميع قراءة مشاريع المطورين النشطين)
CREATE POLICY "المشاريع مرئية للجميع" ON projects
    FOR SELECT USING (
        EXISTS (
            SELECT 1 FROM developers 
            WHERE id = projects.developer_id 
            AND is_active = true
        )
    );

-- سياسات للمهارات
CREATE POLICY "المهارات مرئية للجميع" ON skills
    FOR SELECT USING (
        EXISTS (
            SELECT 1 FROM developers 
            WHERE id = skills.developer_id 
            AND is_active = true
        )
    );

-- سياسات للشهادات
CREATE POLICY "الشهادات مرئية للجميع" ON certificates
    FOR SELECT USING (
        EXISTS (
            SELECT 1 FROM developers 
            WHERE id = certificates.developer_id 
            AND is_active = true
        )
    );



